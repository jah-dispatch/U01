rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is a U01 Admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // THE GLOBAL BADGE: Allows authenticated users to read the global comm feed
    match /{path=**}/statuses/{statusId} {
      allow read: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      
      allow update: if request.auth != null && 
                    request.auth.uid == userId &&
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
                    
      allow update, delete: if isAdmin();
      allow create: if false; 
      
      // Local Write Access: Users can only broadcast to their OWN folder
      match /statuses/{statusId} {
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}